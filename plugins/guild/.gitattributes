# Agent files under agents/generated/ are emitted by `/guild-compile`
# from axes.toml + the source fragments (modes/{domains,phases}/ +
# agents/personalities/) via in-session LLM fusion. Marking them
# linguist-generated collapses them in GitHub diffs and excludes them
# from language stats — they are output, not source.
# Regenerate with `/guild-compile`; do not hand-edit. The check verb
# (`guild compile --check`) fails loud if the committed tree drifts
# from the cache.
agents/generated/** linguist-generated=true
